# EditorConfig 让所有编辑器统一缩进 / 编码 / 行尾
# 详见 https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{c,h,cpp,hpp}]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab

[*.bat]
end_of_line = crlf
